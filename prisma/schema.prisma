generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres", "relationJoins"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EntityStatus {
  NEW // NOUVEAU
  ACTIVE // ACTIF
  INACTIVE // INACTIF
  DELETED // SUPPRIMÉ
}

enum NotificationType {
  ORDER // COMMANDE
  PROMOTION // PROMOTION
  SYSTEM // SYSTÈME
}

enum NotificationTarget {
  USER // UTILISATEUR
  CUSTOMER // CLIENT
}

enum OrderType {
  DELIVERY // LIVRAISON
  PICKUP // RETRAIEMENT
  TABLE // TABLE
}

enum OrderStatus {
  PENDING // EN ATTENTE
  CANCELLED // ANNULÉ
  ACCEPTED // ACCEPTÉ
  IN_PROGRESS // EN COURS
  READY // PRÊT
  PICKED_UP // EN LIVRAISON
  COLLECTED // COLLECTÉ PAR LE CLIENT
  COMPLETED // TERMINÉ, LE LIVREUR A L'ARGENT
}

enum DeliveryService {
  TURBO           // Sous-traité à Turbo Delivery
  FREE            // Legacy — livraison gratuite (compat historique)
  CHICKEN_NATION  // Livreur interne Chicken Nation (module course)
}

enum PaiementMode {
  MOBILE_MONEY // MOBILE MONEY
  WALLET // WALLET
  CARD // CARD
  CASH // ESPÈCES
}

enum PaymentMethod {
  OFFLINE // Au restaurant
  ONLINE // En ligne
}

enum PaiementStatus {
  REVERTED // ANNULÉ
  SUCCESS // SUCCÈS
  FAILED // ÉCHEC
}

enum SupplementCategory {
  FOOD // ALIMENTS
  DRINK // BOISSONS
  ACCESSORY // ACCESSOIRES
}

enum UserType {
  BACKOFFICE // BACKOFFICE
  RESTAURANT // RESTAURANT
}

enum UserRole {
  ADMIN // ADMINISTRATEUR
  MARKETING // MARKETING
  COMPTABLE // COMPTABLE
  CALL_CENTER // CALL CENTER
  MANAGER // GESTIONNAIRE
  ASSISTANT_MANAGER // ASSISTANT GESTIONNAIRE
  CAISSIER // CAISSIER
  CUISINE // CUISINE
}

enum DelivererStatus {
  PENDING_VALIDATION // Inscrit, docs uploadés, en attente de validation admin
  ACTIVE // Validé par admin et opérationnel
  SUSPENDED // Désactivé temporairement
  REJECTED // Refusé par admin
}

enum VehiculeType {
  MOTO // MOTO
  VELO // VELO
  VOITURE // VOITURE
}

enum Genre {
  HOMME // HOMME
  FEMME // FEMME
}

/// Statut de la demande globale de course (vue livreur : le batch entier)
enum CourseStatut {
  PENDING_ASSIGNMENT // Créée, recherche active d'un livreur
  ACCEPTED // Livreur a accepté, en route vers le restaurant
  AT_RESTAURANT // Livreur sur place, a donné le code de retrait
  IN_DELIVERY // Colis récupérés, tournée des clients en cours
  COMPLETED // Toutes les livraisons terminées (succès ou échecs)
  CANCELLED // Annulée avant accomplissement
  EXPIRED // Aucun livreur n'a accepté dans le délai imparti
}

/// Statut d'une livraison individuelle dans le batch d'une course
enum DeliveryStatut {
  PENDING // En attente — livreur pas encore parti vers ce client
  IN_ROUTE // Livreur en route vers ce client
  ARRIVED // Livreur arrivé à l'adresse
  DELIVERED // Livrée avec succès (PIN validé ou preuve photo)
  FAILED // Échec de livraison
  CANCELLED // Annulée (order client annulée pendant la tournée)
}

/// Raisons standard d'échec d'une livraison
enum DeliveryFailureReason {
  CLIENT_ABSENT // Client injoignable à la porte
  CLIENT_REFUSED // Client a refusé la commande
  ADDRESS_NOT_FOUND // Adresse introuvable / fausse
  CLIENT_UNREACHABLE // Téléphone client non joignable
  WRONG_ORDER // Erreur de commande détectée sur place
  OTHER // Motif libre (requiert failure_note)
}

/// État d'un regroupement d'Orders (batch) en attente de flush.
enum CourseBatchStatus {
  PENDING // En cours d'agrégation — d'autres orders peuvent encore rejoindre
  FLUSHED // Course créée à partir de ce batch (flush réussi)
  EXPIRED // Fenêtre écoulée avec 0 order (cas rare — batch vidé avant flush)
}

/// Statut d'une proposition envoyée à UN livreur (audit trail)
enum CourseOfferStatus {
  PENDING // Envoyée, en attente de réponse
  ACCEPTED // Acceptée (devient la course active du livreur)
  REFUSED // Refusée explicitement
  EXPIRED // Pas de réponse dans le délai imparti
}

enum TypeTable {
  TABLE_SQUARE // TABLE CARRE
  TABLE_RECTANGLE // TABLE RECTANGLE
  TABLE_ROUND // TABLE RONDE
}

enum LoyaltyLevel {
  STANDARD // STANDARD
  PREMIUM // PREMIUM
  GOLD // GOLD
}

enum DiscountType {
  PERCENTAGE // POURCENTAGE
  FIXED_AMOUNT // MONTANT FIXE
  BUY_X_GET_Y // ACHETER X, OBTEindre Y
}

enum TargetType {
  ALL_PRODUCTS // TOUT LES PRODUITS
  SPECIFIC_PRODUCTS // PRODUITS SPECIFiques
  CATEGORIES // CATEGORIES
}

enum PromotionStatus {
  DRAFT // Brouillon
  ACTIVE // ACTIF
  EXPIRED // EXPIRÉ
  PAUSED // PAUSE
  CANCELLED // ANNULÉ
}

enum Visibility {
  PUBLIC // PUBLIC
  PRIVATE // PRIVE
}

enum LoyaltyPointType {
  EARNED // Points gagnés
  REDEEMED // Points utilisés
  EXPIRED // Points expirés
  BONUS // Points bonus
}

enum LoyaltyPointIsUsed {
  YES // OUI
  NO // NON
  PARTIAL // PARTIEL
}

enum TicketStatus {
  OPEN // OUVERT
  IN_PROGRESS // EN COURS
  RESOLVED // RÉSOLU
  CLOSED // FERMÉ
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

model Address {
  id String @id @default(uuid()) @db.Uuid

  title       String    @db.VarChar
  address     String    @db.VarChar
  street      String?   @db.VarChar
  city        String?   @db.VarChar
  longitude   Float
  latitude    Float
  customer_id String?   @db.Uuid
  customer    Customer? @relation(fields: [customer_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)
}

model Category {
  id          String  @id @default(uuid()) @db.Uuid
  reference   String? @unique @db.VarChar
  name        String  @db.VarChar
  description String? @db.VarChar
  image       String? @db.Text
  private     Boolean @default(false)
  hubrise_sku String? @unique @db.VarChar

  dishes Dish[]

  entity_status                 EntityStatus                @default(ACTIVE)
  created_at                    DateTime                    @default(now()) @db.Timestamp(6)
  updated_at                    DateTime                    @default(now()) @db.Timestamp(6)
  promotion_targeted_categories PromotionTargetedCategory[]
}

model CounterOtp {
  id      String @id @default(uuid()) @db.Uuid
  counter Int
}

model Comment {
  id String @id @default(uuid()) @db.Uuid

  message String @db.Text
  rating  Float // Note de 1 à 5

  // Relations
  customer_id String   @db.Uuid
  order_id    String   @db.Uuid
  customer    Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  order       Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)

  entity_status EntityStatus @default(ACTIVE)
  created_at    DateTime     @default(now()) @db.Timestamp(6)
  updated_at    DateTime     @default(now()) @db.Timestamp(6)

  @@index([order_id])
  @@index([customer_id])
  @@index([rating])
}

model Customer {
  id String @id @default(uuid()) @db.Uuid

  phone                 String               @unique @db.VarChar
  first_name            String?              @db.VarChar(255)
  last_name             String?              @db.VarChar(255)
  birth_day             DateTime?            @db.Date
  email                 String?              @unique @db.VarChar
  image                 String?              @db.Text
  addresses             Address[]
  favorites             Favorite[]
  orders                Order[]
  notification_settings NotificationSetting?

  // ================================
  // SYSTÈME DE FIDÉLITÉ INTÉGRÉ
  // ================================
  loyalty_level     LoyaltyLevel?
  total_points      Int           @default(0) // Points actuels disponibles
  lifetime_points   Int           @default(0) // Total des points gagnés depuis l'inscription
  last_level_update DateTime?     @db.Timestamp(6)

  // Relations fidélité
  loyalty_points        LoyaltyPoint[]
  promotion_usages      PromotionUsage[]
  loyalty_level_history LoyaltyLevelHistory[]

  entity_status EntityStatus @default(ACTIVE)
  created_at    DateTime     @default(now()) @db.Timestamp(6)
  updated_at    DateTime     @default(now()) @db.Timestamp(6)
  last_login_at DateTime?
  Comment       Comment[]

  // relations conversations, tickets
  TicketMessage TicketMessage[] @relation("TicketMsgAuthorCustomer")

  Message Message[] @relation("MessageAuthorCustomer")

  TicketThread TicketThread[]

  Conversation       Conversation[]
  Voucher            Voucher[]
  cardRequests       CardRequest[]
  nationCards        NationCard[]
  promo_code_usages  PromoCodeUsage[]
  retentionCallbacks RetentionCallback[]
}

// -------------------- Livreurs (deliverers) ------------------------------

model Deliverer {
  id String @id @default(uuid()) @db.Uuid

  // Référence métier affichable (auto-générée : LIV-YYMMDD-XXXXX)
  reference String @unique @db.VarChar(20)

  // Authentification
  phone      String  @unique @db.VarChar
  password   String  @db.VarChar // hash bcrypt du code 4 chiffres
  first_name String? @db.VarChar(255)
  last_name  String? @db.VarChar(255)
  email      String? @unique @db.VarChar
  genre      Genre?
  image      String? @db.Text // URL avatar S3

  // Documents et véhicule (uploadés à l'inscription)
  type_vehicule          VehiculeType?
  piece_identite         String?       @db.Text // URL S3
  permis_conduire        String?       @db.Text // URL S3
  numero_permis          String?       @db.VarChar(100) // Numéro figurant sur le permis
  numero_immatriculation String?       @db.VarChar(50) // Plaque d'immatriculation du véhicule

  // Statut métier
  status         DelivererStatus @default(PENDING_VALIDATION)
  is_operational Boolean         @default(false) // calculé côté service

  // Affectation
  restaurant_id String?     @db.Uuid
  restaurant    Restaurant? @relation(fields: [restaurant_id], references: [id], onDelete: SetNull)

  // Courses (demandes) affectées à ce livreur
  courses        Course[]
  offer_attempts CourseOfferAttempt[]

  // ── Module Schedule (P7 — créneaux & disponibilité) ────────────────────
  // Affectations à des shifts d'un planning, jours de repos, check-ins matinaux.
  schedule_assignments ShiftAssignment[]
  rest_days            RestDay[]
  presence_checks      DailyPresenceCheck[]

  // Sessions
  last_login_at DateTime?
  refresh_token String?   @db.Text // hash du refresh token actif

  // Suppression différée (RGPD + période de grâce 90j)
  // Si non null : compte programmé pour suppression définitive à cette date.
  // Pendant cette période, le user peut se reconnecter et restaurer son compte.
  deletion_scheduled_at DateTime? @db.Timestamp(6)

  // ── Géolocalisation temps réel ─────────────────────────────────────────
  // Remontée par le mobile via POST /deliverer/me/location toutes les X sec
  // (X = `deliverer.gps_update_interval_seconds` en settings, default 60s).
  // Utilisée par le DelivererScoringService pour pondérer la distance
  // au restaurant dans le choix du livreur à qui envoyer une offre.
  last_location    Json?     // { lat: number, lng: number }
  last_location_at DateTime? @db.Timestamp(6)
  last_speed_kmh   Float?    // vitesse instantanée (m/s → km/h côté mobile)
  last_heading_deg Float?    // direction 0-360° (bonus pour flèche map admin)

  // ── File d'attente FIFO & pénalités ────────────────────────────────────
  // `last_available_at` : timestamp d'entrée en queue (null = pas dispo).
  // Le tri FIFO est `ORDER BY last_available_at ASC` — plus ancien = servi d'abord.
  last_available_at DateTime? @db.Timestamp(6)

  // Pause manuelle (bouton "Je prends une pause" côté mobile).
  pause_until DateTime? @db.Timestamp(6)

  // Pause forcée après N refus consécutifs en X min (auto_pause_*).
  auto_pause_until DateTime? @db.Timestamp(6)

  // Pénalité queue après un refus : descend de N positions pendant X min.
  queue_penalty_until      DateTime? @db.Timestamp(6)
  queue_penalty_positions  Int?      @default(0)

  // Historique timestamps des derniers refus/expirations d'offres — JSON
  // array de strings ISO. Utilisé pour compter les refus dans une fenêtre
  // glissante (cf. auto_pause_refusals_window_min).
  recent_refusals Json?

  // ── Push notifications (Expo Push) ─────────────────────────────────────
  // Token Expo enregistré au login mobile. Sert à `ExpoPushService` pour
  // envoyer des notifications (nouveau message support, nouvelle course,
  // auto-pause, etc.). Re-set à chaque login pour suivre les changements
  // (re-install app, restore device, etc.).
  expo_push_token String? @db.VarChar(255)

  // ── Tickets support (P-chat livreur ↔ support) ─────────────────────────
  // Le livreur peut ouvrir des tickets de support via l'app mobile, et
  // recevoir des messages d'agents support depuis le backoffice.
  support_tickets         TicketThread[]  @relation("DelivererTickets")
  support_ticket_messages TicketMessage[] @relation("DelivererTicketMessages")

  entity_status EntityStatus @default(ACTIVE)
  created_at    DateTime     @default(now()) @db.Timestamp(6)
  updated_at    DateTime     @default(now()) @db.Timestamp(6)

  @@index([phone])
  @@index([status])
  @@index([restaurant_id])
  @@index([deletion_scheduled_at])
  @@index([last_available_at])
  @@index([pause_until])
  @@index([auto_pause_until])
}

// -------------------- Courses / Livraisons ---------------------------------
// Modèle central qui représente la "demande de course" envoyée au livreur.
// Une Course regroupe 1..N Delivery (livraisons individuelles).

/// Demande de course = regroupement de livraisons proposées à un livreur.
/// La `reference` sert aussi de code de retrait au restaurant.
model Course {
  id String @id @default(uuid()) @db.Uuid

  /// Référence unique interne : CRS-YYMMDD-XXXXX (tracking + logs + URLs)
  reference String @unique @db.VarChar(20)

  /// Code de retrait à 3 chiffres donné au restaurant par le livreur.
  /// NON unique : collisions possibles (1000 codes, tolérables à l'échelle d'un resto).
  /// En cas de collision, le resto discrimine via le livreur et la commande.
  pickup_code String @db.VarChar(3)

  statut CourseStatut @default(PENDING_ASSIGNMENT)

  /// Livreur affecté (null tant qu'aucun n'a accepté)
  deliverer_id String?    @db.Uuid
  deliverer    Deliverer? @relation(fields: [deliverer_id], references: [id], onDelete: SetNull)

  /// Restaurant d'origine (toutes les livraisons partent du même resto)
  restaurant_id String     @db.Uuid
  restaurant    Restaurant @relation(fields: [restaurant_id], references: [id])

  /// Livraisons groupées dans cette demande (1..N)
  deliveries Delivery[]

  /// Historique des propositions envoyées aux livreurs
  offer_attempts CourseOfferAttempt[]

  /// Batch de regroupement d'origine (si la Course est issue du grouping auto).
  /// Null si créée "en legacy" (1 order = 1 course sans batch).
  batch CourseBatch?

  // === Timeline ===
  assigned_at      DateTime? @db.Timestamp(6) // livreur a accepté
  at_restaurant_at DateTime? @db.Timestamp(6) // livreur arrivé au resto (GPS ou action manuelle)
  picked_up_at     DateTime? @db.Timestamp(6) // code retrait donné, colis récupérés par la caissière
  completed_at     DateTime? @db.Timestamp(6) // toutes livraisons terminées
  cancelled_at     DateTime? @db.Timestamp(6)
  cancelled_by     String?   @db.VarChar // "admin" | "deliverer" | "restaurant" | "system"
  cancelled_reason String?   @db.VarChar

  // === Mécanique d'affectation ===
  /// Moment où l'offer PENDING actuelle expire
  offer_expires_at DateTime? @db.Timestamp(6)
  /// Cumul des livreurs ayant refusé (stat de difficulté)
  refusal_count    Int       @default(0)

  // === Financier ===
  total_delivery_fee     Float
  estimated_duration_min Int?

  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)

  @@index([deliverer_id, statut])
  @@index([restaurant_id, statut])
  @@index([statut, offer_expires_at]) // utile pour le cron d'expiration
}

/// Une livraison individuelle dans le batch d'une course.
/// 1 Delivery = 1 Order à livrer à 1 client.
model Delivery {
  id String @id @default(uuid()) @db.Uuid

  /// Course (demande) à laquelle appartient cette livraison
  course_id String @db.Uuid
  course    Course @relation(fields: [course_id], references: [id], onDelete: Cascade)

  /// Ordre dans la tournée (1, 2, 3…) — optimisation itinéraire
  sequence_order Int

  /// Order client livrée (relation 1-1)
  order_id String @unique @db.Uuid
  order    Order  @relation(fields: [order_id], references: [id])

  statut DeliveryStatut @default(PENDING)

  /// Code 4 chiffres donné au client via notification pour confirmer la réception.
  delivery_pin String @db.VarChar(4)

  // === Timeline par livraison ===
  in_route_at  DateTime? @db.Timestamp(6) // livreur en route vers ce client
  arrived_at   DateTime? @db.Timestamp(6) // livreur arrivé
  delivered_at DateTime? @db.Timestamp(6) // PIN validé / preuve fournie
  failed_at    DateTime? @db.Timestamp(6)

  // === Échec ===
  failure_reason DeliveryFailureReason?
  failure_note   String?                @db.VarChar(500)

  // === Preuve (fallback si client sans PIN) ===
  proof_image String? @db.Text // key S3 sous chicken-nation/deliveries-proof/

  // === Notation du client par le livreur (post-livraison, optionnel) ===
  // Le livreur peut noter le client après une livraison (DELIVERED ou FAILED)
  // pour signaler les comportements (ex: client agressif, lieu difficile,
  // adresse fausse). Utilisé par les ops pour identifier les clients problématiques.
  customer_rating      Int?      @db.SmallInt // 1-5
  customer_rating_note String?   @db.VarChar(500)
  customer_rated_at    DateTime? @db.Timestamp(6)

  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)

  @@unique([course_id, sequence_order]) // pas de doublon dans la tournée
  @@index([course_id, statut])
  @@index([order_id])
  @@index([customer_rating]) // stats côté ops
}

/// Audit trail des propositions envoyées aux livreurs.
/// - Permet le retry automatique après refus/timeout
/// - Trace qui a refusé quoi pour stats
model CourseOfferAttempt {
  id String @id @default(uuid()) @db.Uuid

  course_id String @db.Uuid
  course    Course @relation(fields: [course_id], references: [id], onDelete: Cascade)

  deliverer_id String    @db.Uuid
  deliverer    Deliverer @relation(fields: [deliverer_id], references: [id])

  status         CourseOfferStatus @default(PENDING)
  offered_at     DateTime          @default(now()) @db.Timestamp(6)
  expires_at     DateTime          @db.Timestamp(6) // offered_at + 30s
  responded_at   DateTime?         @db.Timestamp(6)
  refusal_reason String?           @db.VarChar(500)

  created_at DateTime @default(now()) @db.Timestamp(6)

  @@index([deliverer_id, status])
  @@index([course_id])
  @@index([status, expires_at]) // cron d'expiration

  /// A1 Fix — Partial unique index ajouté via migration ciblée :
  ///   CREATE UNIQUE INDEX "CourseOfferAttempt_pending_unique"
  ///     ON "CourseOfferAttempt" ("course_id", "deliverer_id")
  ///     WHERE "status" = 'PENDING';
  /// Garantit qu'au plus UNE offer PENDING existe par couple
  /// (course, deliverer) à un instant T. Les statuts terminaux
  /// (ACCEPTED, REFUSED, EXPIRED) restent libres de doublons.
  /// Prisma 6 ne supporte pas encore les WHERE clauses sur @@unique,
  /// d'où la migration SQL brute (cf. 20260425101807_course_offer_pending_unique).
}

/// Regroupement intelligent de commandes en attente de création de Course.
///
/// Flow : quand une Order passe READY, `CourseGroupingService.tryGroupOrder(orderId)`
/// attache l'order à un batch PENDING existant (même restaurant, compatible) ou
/// en crée un nouveau avec TTL = `course.batch_window_seconds` (default 180 s).
///
/// Le batch est flush (→ Course créée) :
///   - Immédiatement quand il atteint `course.max_orders_per_course`
///   - Ou quand `expires_at` est dépassé (cron `CourseBatchTask` toutes les 10 s)
///
/// Un batch reste visible en DB même après flush pour audit / debug.
model CourseBatch {
  id            String @id @default(uuid()) @db.Uuid
  restaurant_id String @db.Uuid
  restaurant    Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)

  /// État courant du batch (PENDING → FLUSHED ou EXPIRED).
  status CourseBatchStatus @default(PENDING)

  /// Fenêtre de fermeture automatique : now + `course.batch_window_seconds`.
  /// Le cron `CourseBatchTask` flush tous les batches PENDING dont `expires_at <= now`.
  expires_at DateTime @db.Timestamp(6)

  /// Commandes en attente dans ce batch (1..N via relation inverse `Order.batch`).
  orders Order[]

  /// Course créée au flush (null tant que PENDING ou EXPIRED sans flush).
  course_id  String? @unique @db.Uuid
  course     Course? @relation(fields: [course_id], references: [id], onDelete: SetNull)
  flushed_at DateTime? @db.Timestamp(6)

  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)

  @@index([restaurant_id, status])
  @@index([status, expires_at]) // cron de flush
}

// -------------------- Gestion des conversations ------------------------------

model Conversation {
  id      String  @id @default(uuid()) @db.Uuid
  subject String? @db.VarChar

  restaurantId String?     @db.Uuid
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id])

  customerId String?   @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id])

  users    ConversationUser[]
  messages Message[]

  // multi-escalades : 1 conv -> N tickets
  escalations TicketThread[] @relation("FromConversation")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ConversationUser {
  conversationId String @db.Uuid
  userId         String @db.Uuid

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  joinedAt DateTime @default(now()) // Date de jointure

  @@id([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @db.Uuid
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  // Auteur (les 2 ne peuvent etre null a la fois)
  authorUserId     String?   @db.Uuid
  authorUser       User?     @relation("MessageAuthorUser", fields: [authorUserId], references: [id])
  authorCustomerId String?   @db.Uuid
  authorCustomer   Customer? @relation("MessageAuthorCustomer", fields: [authorCustomerId], references: [id])

  body      String
  meta      Json? // Image, vidéo, fichier, etc.
  isRead    Boolean  @default(false) // Si le message a été lu
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId, createdAt])
  @@index([authorUserId])
  @@index([authorCustomerId])
}

// ---------- Tickets (support) ----------

// Cette table represente les tickets de support
model TicketThread {
  id String @id @default(uuid()) @db.Uuid

  subject  String
  code     String         @unique @db.VarChar // ex: TCK-0001
  status   TicketStatus   @default(OPEN)
  priority TicketPriority @default(MEDIUM)
  source   String? // ex: phone, email, webform, escalation

  // C'est un client qui contacte le support
  customerId String?   @db.Uuid
  customer   Customer? @relation(fields: [customerId], references: [id])

  // OU c'est un livreur qui contacte le support (P-chat livreur)
  // Mutuellement exclusif avec customerId — un ticket vient d'UN seul demandeur.
  delivererId String?    @db.Uuid
  deliverer   Deliverer? @relation("DelivererTickets", fields: [delivererId], references: [id])

  // Catégorie du ticket
  categoryId String?         @db.Uuid
  category   TicketCategory? @relation(fields: [categoryId], references: [id])

  // Assignation agent support
  assigneeId String? @db.Uuid
  assignee   User?   @relation("TicketAssignee", fields: [assigneeId], references: [id])

  // multi-escalades : N tickets peuvent référencer la même conversation
  fromConversationId String?       @db.Uuid
  fromConversation   Conversation? @relation("FromConversation", fields: [fromConversationId], references: [id])

  // Participants & messages
  participants TicketParticipant[]
  messages     TicketMessage[]

  // commande lié au ticket
  orderId String? @db.Uuid
  order   Order?  @relation(fields: [orderId], references: [id])

  // SLA / métriques
  firstResponseAt DateTime?
  resolvedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, priority])
  @@index([assigneeId])
  @@index([customerId])
  @@index([delivererId])
  @@index([fromConversationId])
}

// Cette table represente les "employes" qui repondent au ticket d'un client
model TicketParticipant {
  ticketId String       @db.Uuid
  userId   String       @db.Uuid
  ticket   TicketThread @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime     @default(now())

  @@id([ticketId, userId])
  @@index([userId])
}

model TicketMessage {
  id       String       @id @default(uuid()) @db.Uuid
  ticketId String       @db.Uuid
  ticket   TicketThread @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  // Les authors sont mutuellement exclusifs — exactement un des trois doit être non-null.
  authorUserId     String?   @db.Uuid
  authorUser       User?     @relation("TicketMsgAuthorUser", fields: [authorUserId], references: [id])
  authorCustomerId String?   @db.Uuid
  authorCustomer   Customer? @relation("TicketMsgAuthorCustomer", fields: [authorCustomerId], references: [id])
  // Auteur livreur (P-chat livreur) — exclusif avec les 2 autres.
  authorDelivererId String?    @db.Uuid
  authorDeliverer   Deliverer? @relation("DelivererTicketMessages", fields: [authorDelivererId], references: [id])

  body      String
  meta      Json?
  createdAt DateTime @default(now())

  isRead   Boolean @default(false) // Si le message a été lu
  internal Boolean @default(false) // Si le message est pour usage interne

  @@index([ticketId, createdAt])
  @@index([authorUserId])
  @@index([authorCustomerId])
  @@index([authorDelivererId])
  @@index([isRead])
}

model TicketCategory {
  id            String       @id @default(uuid()) @db.Uuid
  name          String       @unique @db.VarChar
  description   String?      @db.Text
  entity_status EntityStatus @default(ACTIVE)

  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)

  agents       TicketUserSkill[] @relation("CategoryAgents")
  TicketThread TicketThread[]

