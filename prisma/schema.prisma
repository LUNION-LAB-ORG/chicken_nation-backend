// Configuration du système de fidélité
model LoyaltyConfig {
  id                        String @id @default(uuid()) @db.Uuid
  points_per_xof            Float  @default(0.002) // 2 points par 1000 XOF dépensé
  points_expiration_days    Int?   @default(365) // Points expirent après X jours
  minimum_redemption_points Int    @default(100) // Pour 100 points, on peut acheter un plat de 2000 XOF
  point_value_in_xof        Float  @default(20) // 1 point = 20 XOF

  // Seuils pour les niveaux de fidélité
  standard_threshold Int @default(300) // 300 points pour Standard
  premium_threshold  Int @default(700) // 700 points pour Premium
  gold_threshold     Int @default(1000) // 1000 points pour Gold

  is_active  Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)
}

// ================================
// # Bon d'achat
// ================================

enum VoucherStatus {
  ACTIVE
  REDEEMED
  EXPIRED
  CANCELLED
}

model Voucher {
  id               String        @id @default(uuid()) @db.Uuid
  code             String        @unique @db.VarChar
  initial_amount   Float // Montant initial du bon
  remaining_amount Float // Montant restant
  customer_id      String        @db.Uuid
  customer         Customer      @relation(fields: [customer_id], references: [id])
  status           VoucherStatus @default(ACTIVE)
  redeemed_at      DateTime?     @db.Timestamp(6) // Date de rédemption
  expires_at       DateTime?     @db.Timestamp(6) // Date d'expiration
  created_at       DateTime      @default(now()) @db.Timestamp(6)
  updated_at       DateTime      @default(now()) @db.Timestamp(6)
  Redemption       Redemption[]

  created_by    String       @db.Uuid
  creator       User         @relation(fields: [created_by], references: [id])
  entity_status EntityStatus @default(ACTIVE)
}

model Redemption {
  id            String       @id @default(uuid()) @db.Uuid
  voucher_id    String       @db.Uuid
  order_id      String       @db.Uuid
  amount        Float // Montant utilisé lors de la rédemption
  voucher       Voucher      @relation(fields: [voucher_id], references: [id])
  order         Order        @relation(fields: [order_id], references: [id])
  created_at    DateTime     @default(now()) @db.Timestamp(6)
  entity_status EntityStatus @default(ACTIVE)
}

// ================================
// CODES PROMO
// ================================

model PromoCode {
  id                  String           @id @default(uuid()) @db.Uuid
  code                String           @unique @db.VarChar
  description         String?          @db.Text
  discount_type       DiscountType
  discount_value      Float
  min_order_amount    Float?           @default(0)
  max_discount_amount Float?
  max_usage           Int?
  max_usage_per_user  Int?             @default(1)
  usage_count         Int              @default(0)
  start_date          DateTime         @db.Timestamp(6)
  expiration_date     DateTime         @db.Timestamp(6)
  is_active           Boolean          @default(true)
  restaurant_ids      String[]         @default([])
  created_by          String?          @db.Uuid
  creator             User?            @relation("promo_code_creator", fields: [created_by], references: [id])
  created_at          DateTime         @default(now()) @db.Timestamp(6)
  updated_at          DateTime         @updatedAt @db.Timestamp(6)
  entity_status       EntityStatus     @default(ACTIVE)
  usages              PromoCodeUsage[]

  @@index([code])
  @@index([is_active, entity_status])
}

model PromoCodeUsage {
  id              String    @id @default(uuid()) @db.Uuid
  promo_code_id   String    @db.Uuid
  promo_code      PromoCode @relation(fields: [promo_code_id], references: [id])
  customer_id     String    @db.Uuid
  customer        Customer  @relation(fields: [customer_id], references: [id])
  order_id        String?   @db.Uuid
  order           Order?    @relation(fields: [order_id], references: [id])
  discount_amount Float
  created_at      DateTime  @default(now()) @db.Timestamp(6)

  @@index([promo_code_id])
  @@index([customer_id])
}

