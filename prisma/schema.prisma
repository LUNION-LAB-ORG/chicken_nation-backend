// Table de liaison pour les plats inclus dans une promotion
model PromotionDish {
  id           String @id @default(uuid()) @db.Uuid
  promotion_id String @db.Uuid
  dish_id      String @db.Uuid
  quantity     Int    @default(1) // Pour les offres "Buy X Get Y"

