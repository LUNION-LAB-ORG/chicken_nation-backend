// ========================
// RÉTENTION CLIENTS
// ========================

enum RetentionCallbackStatus {
  CALLED
  NO_ANSWER
  CALLBACK_SCHEDULED
  RECONQUERED
  LOST
}

model RetentionCallbackReason {
  id            String              @id @default(uuid()) @db.Uuid
  name          String              @db.VarChar(255)
  description   String?             @db.Text
  is_active     Boolean             @default(true)
  position      Int                 @default(0)
  callbacks     RetentionCallback[]
  entity_status EntityStatus        @default(ACTIVE)
  created_at    DateTime            @default(now()) @db.Timestamp(6)
  updated_at    DateTime            @default(now()) @db.Timestamp(6)

  @@map("retention_callback_reasons")
}

model RetentionCallback {
  id               String                   @id @default(uuid()) @db.Uuid
  customer_id      String                   @db.Uuid
  customer         Customer                 @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  caller_user_id   String                   @db.Uuid
  caller           User                     @relation("RetentionCallbacks", fields: [caller_user_id], references: [id])
  reason_id        String?                  @db.Uuid
  reason           RetentionCallbackReason? @relation(fields: [reason_id], references: [id])
  status           RetentionCallbackStatus  @default(CALLED)
  notes            String?                  @db.Text
  called_at        DateTime                 @default(now()) @db.Timestamp(6)
  next_callback_at DateTime?                @db.Timestamp(6)
  reconquered_at   DateTime?                @db.Timestamp(6)
  parent_id        String?                  @db.Uuid
  parent           RetentionCallback?       @relation("CallbackChain", fields: [parent_id], references: [id])
  followups        RetentionCallback[]      @relation("CallbackChain")
  entity_status    EntityStatus             @default(ACTIVE)
  created_at       DateTime                 @default(now()) @db.Timestamp(6)
  updated_at       DateTime                 @default(now()) @db.Timestamp(6)

  @@index([customer_id])
  @@index([status])
  @@index([next_callback_at])
  @@map("retention_callbacks")
}

// ============================================================
// MODULE SCHEDULE — créneaux & disponibilité livreurs (P7)
// ============================================================
//
// Workflow général :
//   1. ADMIN génère un plan (ex : 2 semaines) via la matrice livreur×jours.
//   2. Le service `SchedulePlanningService` calcule automatiquement :
//      - les jours de repos en rotation FIFO sur `rotation_cycle_weeks`
//      - le nombre de slots matin/soir en fonction du volume estimé
//        (`weekday_volume_multiplier`, `weekend_volume_multiplier`)
//      - les `ShiftAssignment` (PROPOSED) pour chaque (livreur, jour, shift)
//   3. ADMIN review et SEND → status=SENT, push WS aux livreurs.
//   4. Chaque livreur ACCEPTE / REFUSE chaque jour proposé via mobile.
//   5. À 8h chaque matin : push de check-in "Tu es opérationnel aujourd'hui ?"
//      Réponse OUI / NON / pas de réponse (auto-CONFIRMED après X minutes).
//   6. Le livreur peut ajouter / retirer un jour de repos pour LUI-MÊME
//      depuis le mobile (n'impacte pas les autres livreurs du plan).
//
// Tous les paramètres (durée plans, rotation, shifts, volumes, deadlines)
// sont dans `schedule.*` settings — voir `ScheduleSettingsHelper`.

/// Statut d'un plan de planning au cours de son cycle de vie.
enum SchedulePlanStatus {
  DRAFT     // En cours d'édition par l'admin (auto-généré ou manuel)
  SENT      // Envoyé aux livreurs, en attente de leurs confirmations
  CONFIRMED // Tous les livreurs ont répondu (ou deadline passée + auto-CONFIRMED)
  ARCHIVED  // Période passée, plan figé pour historique
}

/// Type de créneau journalier — 2 paliers seulement (matin/soir) pour rester simple.
enum ShiftType {
  MORNING // ex : 09h-15h
  EVENING // ex : 15h-23h
}

/// Statut d'une affectation livreur ↔ shift.
enum ShiftAssignmentStatus {
  ASSIGNED   // Pré-affecté par l'algo, en attente de réponse livreur
  CONFIRMED  // Livreur a confirmé sa présence (ou auto-CONFIRMED par deadline)
  REFUSED    // Livreur a explicitement décliné le shift
}

/// Origine d'un jour de repos.
enum RestDaySource {
  AUTO              // Calculé par l'algo de rotation
  MANUAL_DELIVERER  // Le livreur a ajouté ce repos lui-même via mobile
  MANUAL_ADMIN      // L'admin a forcé ce repos (gestion exceptionnelle)
}

/// Réponse au check-in matinal de présence.
enum PresenceCheckResponse {
  PRESENT     // "Oui je suis op aujourd'hui"
  ABSENT      // "Non je ne peux pas"
  NO_RESPONSE // Pas de réponse → auto-CONFIRMED PRESENT (politique Q6=A)
}

/// Plan de créneaux pour un restaurant sur une période donnée.
/// Émis par l'admin (manuellement ou auto-généré). Contient 1..N Shift.
model SchedulePlan {
  id String @id @default(uuid()) @db.Uuid

  restaurant_id String     @db.Uuid
  restaurant    Restaurant @relation(fields: [restaurant_id], references: [id], onDelete: Cascade)

  /// Période couverte par ce plan (inclus). Typiquement 2 semaines.
  period_start DateTime @db.Date
  period_end   DateTime @db.Date

  status SchedulePlanStatus @default(DRAFT)

  /// Snapshot du nombre de livreurs ayant CONFIRMED au moment du SEND →
  /// permet de track le taux de confirmation sans recalcul.
  confirmed_count Int @default(0)

  /// Timestamps des transitions (audit + métriques).
  sent_at      DateTime? @db.Timestamp(6)
  confirmed_at DateTime? @db.Timestamp(6) // Quand toutes les réponses sont collectées
  archived_at  DateTime? @db.Timestamp(6)

  /// Shifts générés pour cette période (1 par jour × shift_type).
  shifts Shift[]

  entity_status EntityStatus @default(ACTIVE)
  created_at    DateTime     @default(now()) @db.Timestamp(6)
  updated_at    DateTime     @default(now()) @db.Timestamp(6)

  @@index([restaurant_id, status])
  @@index([period_start, period_end])
}

/// Créneau journalier dans un plan (matin OU soir, pour 1 jour donné).
model Shift {
  id String @id @default(uuid()) @db.Uuid

  plan_id String       @db.Uuid
  plan    SchedulePlan @relation(fields: [plan_id], references: [id], onDelete: Cascade)

  /// Jour calendaire couvert par ce shift.
  date DateTime @db.Date

  type ShiftType

  /// Heures d'ouverture du shift (HH:mm). Snapshots des settings au moment
  /// de la génération du plan — un changement futur des settings n'altère
  /// pas les plans déjà envoyés.
  start_time String @db.VarChar(5) // ex : "09:00"
  end_time   String @db.VarChar(5) // ex : "15:00"

  /// Capacité maximale en livreurs sur ce shift.
  /// Calculée par `SchedulePlanningService` selon le volume estimé.
  max_slots Int

  /// Affectations livreur ↔ shift (1..max_slots — l'algo n'en crée jamais plus).
  assignments ShiftAssignment[]

  entity_status EntityStatus @default(ACTIVE)
  created_at    DateTime     @default(now()) @db.Timestamp(6)
  updated_at    DateTime     @default(now()) @db.Timestamp(6)

  @@unique([plan_id, date, type]) // 1 shift matin + 1 shift soir par jour max
  @@index([plan_id])
  @@index([date])
}

/// Affectation d'un livreur à un shift, avec son statut de confirmation.
model ShiftAssignment {
  id String @id @default(uuid()) @db.Uuid

  shift_id String @db.Uuid
  shift    Shift  @relation(fields: [shift_id], references: [id], onDelete: Cascade)

  deliverer_id String    @db.Uuid
  deliverer    Deliverer @relation(fields: [deliverer_id], references: [id], onDelete: Cascade)

  status ShiftAssignmentStatus @default(ASSIGNED)

  /// Timestamps des transitions (audit).
  confirmed_at DateTime? @db.Timestamp(6)
  refused_at   DateTime? @db.Timestamp(6)

  /// Raison de refus (optionnelle, libre).
  refusal_reason String? @db.VarChar(500)

  entity_status EntityStatus @default(ACTIVE)
  created_at    DateTime     @default(now()) @db.Timestamp(6)
  updated_at    DateTime     @default(now()) @db.Timestamp(6)

  /// Pas 2 affectations du même livreur sur le même shift.
  @@unique([shift_id, deliverer_id])
  @@index([deliverer_id, status])
  @@index([shift_id])
}

/// Jour de repos d'un livreur. Peut être issu de l'algo (rotation FIFO),
/// du livreur lui-même (toggle mobile), ou de l'admin (gestion exceptionnelle).
///
/// Les RestDay sont indépendants des plans : ils s'expriment au niveau livreur
/// pour pouvoir évoluer en cours de plan (ex : le livreur retire son repos
/// du mardi pour celui du mercredi).
model RestDay {
  id String @id @default(uuid()) @db.Uuid

  deliverer_id String    @db.Uuid
  deliverer    Deliverer @relation(fields: [deliverer_id], references: [id], onDelete: Cascade)

  /// Jour de repos (date pure, pas de time).
  date DateTime @db.Date

  source RestDaySource @default(AUTO)

  /// Raison libre (ex : "vacances", "maladie", "marriage cousin").
  reason String? @db.VarChar(500)

  entity_status EntityStatus @default(ACTIVE)
  created_at    DateTime     @default(now()) @db.Timestamp(6)
  updated_at    DateTime     @default(now()) @db.Timestamp(6)

  /// Un livreur ne peut pas avoir 2 RestDay le même jour.
  @@unique([deliverer_id, date])
  @@index([date])
}

/// Réponse d'un livreur au check-in matinal "Tu es opérationnel aujourd'hui ?"
///
/// Push envoyé chaque jour à `daily_presence_check_hour` (default 8h).
/// Si pas de réponse dans la fenêtre, auto-CONFIRMED PRESENT (Q6=A).
/// Sert à détecter les absences silencieuses pour l'admin (compte rendu daily).
model DailyPresenceCheck {
  id String @id @default(uuid()) @db.Uuid

  deliverer_id String    @db.Uuid
  deliverer    Deliverer @relation(fields: [deliverer_id], references: [id], onDelete: Cascade)

  /// Jour du check-in.
  date DateTime @db.Date

  response PresenceCheckResponse @default(NO_RESPONSE)

  /// Timestamp de la réponse explicite. Null si NO_RESPONSE auto-CONFIRMED.
  responded_at DateTime? @db.Timestamp(6)

  /// Snapshot du shift principal du jour (pour stats sans rejoin).
  shift_type ShiftType?

  entity_status EntityStatus @default(ACTIVE)
  created_at    DateTime     @default(now()) @db.Timestamp(6)
  updated_at    DateTime     @default(now()) @db.Timestamp(6)

  /// Un seul check-in par livreur par jour.
  @@unique([deliverer_id, date])
  @@index([date, response])
}
