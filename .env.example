# HUBRISE
HUBRISE_CLIENT_ID=""          # Client ID de l'application HubRise
HUBRISE_CLIENT_SECRET=""      # Client Secret de l'application HubRise
HUBRISE_ACCESS_TOKEN=""       # Token global (optionnel, sinon chaque restaurant a son propre token)
HUBRISE_WEBHOOK_SECRET=""     # Secret HMAC pour la vérification des callbacks
FRONTEND_URL=""             # URL du backoffice pour les redirections OAuth (ex: https://backoffice.chicken-nation.com)

# ─── Google Maps (proxy backend /maps/*) ─────────────────────────────────────
