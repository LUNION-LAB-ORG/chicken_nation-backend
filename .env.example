# SECURITY
# CORS_ORIGINS : liste de domaines autorisés pour CORS, séparés par des virgules.
# Si vide, fallback sur la liste hardcodée dans main.ts (Vercel + chicken-nation.com + localhost).
CORS_ORIGINS=https://chicken-nation-backoffice.vercel.app,https://chicken-nation.com,https://www.chicken-nation.com,http://localhost:3000,http://localhost:4006
# CORS_ORIGIN (legacy, gardé pour compat) :
CORS_ORIGIN=http://localhost:${PORT}

# CONFIGURATION ORDER
ORDER_TAX_RATE=0.005
BASE_DELIVERY_FEE=1

# TWILIO
ACCOUNT_SID=""
AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
